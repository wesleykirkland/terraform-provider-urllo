# Local CLI configs (contain machine-specific paths).
dev.tfrc
mirror.tfrc

# Repo-local provider mirror (see build-local.sh TF_PLUGIN_MIRROR).
.terraform-mirror/

# Terraform working files.
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
.terraform.tfstate.lock.info

# CCE (code-context-engine)
# CCE local cache (per-machine, not for version control)
.cce/
# Claude Code local settings written by cce init
.claude/settings.local.json
# .mcp.json contains absolute paths regenerated by `cce init`
.mcp.json
